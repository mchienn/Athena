# OpenAI-compatible endpoint. Ví dụ Vertex AI (thay PROJECT_ID và LOCATION):
# https://LOCATION-aiplatform.googleapis.com/v1/projects/PROJECT_ID/locations/LOCATION/endpoints/openapi
OPENAI_BASE_URL=https://LOCATION-aiplatform.googleapis.com/v1/projects/PROJECT_ID/locations/LOCATION/endpoints/openapi

# Tên model mà endpoint chấp nhận. Prefix openai/ sẽ được thêm tự động cho LiteLLM.
HOSPITAL_ASSISTANT_MODEL=google/gemini-2.5-flash

# Cách 1: API key tĩnh của OpenAI-compatible endpoint.
# Để trống nếu dùng Google Application Default Credentials (ADC).
OPENAI_API_KEY=

# Cách 2: với Vertex AI, chạy `gcloud auth application-default login`, hoặc trỏ
# biến dưới đây đến service-account JSON. Không commit file JSON vào Git.
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Gemini Developer API (Files API) dùng khi đồng bộ PDF/ảnh và OCR bảng scan.
# Files API hiện yêu cầu Gemini API key; không commit key thật vào Git.
GEMINI_API_KEY=
GEMINI_DOCUMENT_MODEL=gemini-2.5-flash

# auto: dùng Gemini Files API nếu có GEMINI_API_KEY, nếu không dùng OPENAI_BASE_URL
# với PDF/ảnh inline. Có thể ép thành files_api hoặc openai_compatible.
DOCUMENT_EXTRACTION_BACKEND=auto
# Để trống để dùng HOSPITAL_ASSISTANT_MODEL cho backend OpenAI-compatible.
DOCUMENT_EXTRACTION_MODEL=

# Kho dữ liệu đã trích xuất để price agent tra cứu. Đường dẫn tương đối tính từ thư mục chạy.
HOSPITAL_KNOWLEDGE_PATH=hanoi_heart_assistant/data/hospital_knowledge.json

# Chỉ bật khi muốn price agent có thêm Playwright MCP để duyệt trực tiếp.
# Production nên để false và chạy đồng bộ định kỳ thay vì cấp browser cho mỗi phiên chat.
ENABLE_PLAYWRIGHT_MCP=false
PLAYWRIGHT_MCP_COMMAND=npx
PLAYWRIGHT_MCP_PACKAGE=@playwright/mcp@latest
PLAYWRIGHT_MCP_CONNECTION_TIMEOUT=60
PLAYWRIGHT_MCP_ACTION_TIMEOUT_MS=15000
PLAYWRIGHT_MCP_NAVIGATION_TIMEOUT_MS=90000
HOSPITAL_WEB_SEARCH_MAX_PAGES=12
HOSPITAL_PAGE_TIMEOUT_MS=45000
HOSPITAL_CRAWL_RETRIES=2

# Firestore Vector Search. FIREBASE_PROJECT_ID có thể để trống nếu ADC hoặc
# OPENAI_BASE_URL đã xác định đúng Google Cloud project.
FIREBASE_PROJECT_ID=
FIRESTORE_DATABASE=(default)
FIRESTORE_VECTOR_COLLECTION=hospital_knowledge_chunks
HOSPITAL_EMBEDDING_BACKEND=google_genai_vertex
HOSPITAL_EMBEDDING_MODEL=gemini-embedding-001
HOSPITAL_EMBEDDING_DIMENSION=768
FIREBASE_EMBEDDING_LOCATION=global
HOSPITAL_EMBEDDING_BATCH_SIZE=5
HOSPITAL_VECTOR_CHUNK_CHARS=3500
HOSPITAL_VECTOR_CHUNK_OVERLAP=300
FIREBASE_VECTOR_PRUNE_STALE=true
MAX_BOOKINGS_PER_SHIFT=6

# JWT session. Đặt JWT_SECRET_KEY bằng giá trị ngẫu nhiên dài trong môi trường thật.
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
# true khi frontend/API chạy qua HTTPS; `lax` phù hợp khi cùng site.
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
FIRESTORE_REFRESH_SESSIONS_COLLECTION=refresh_sessions

# URL gốc của frontend; appointment agent dùng để mở biểu mẫu đặt lịch.
FRONTEND_URL=http://localhost:3000


# Cho phép price agent tự crawl/OCR và cập nhật kho dữ liệu khi kết quả thiếu hoặc cũ.
# Tác vụ này có thể tốn thời gian và token model; chỉ bật ở backend tin cậy.
ALLOW_AGENT_KNOWLEDGE_REFRESH=false
HOSPITAL_REFRESH_MAX_PAGES=40
