[
  {
    "name": "athena_agent_model_calls",
    "description": "ADK model calls by agent, model and outcome.",
    "filter": "resource.type=\"cloud_run_revision\" AND jsonPayload.telemetry_type=\"agent\" AND jsonPayload.event_name=\"model_call\"",
    "metricDescriptor": {
      "metricKind": "DELTA",
      "valueType": "INT64",
      "unit": "1",
      "labels": [
        {"key": "agent", "valueType": "STRING"},
        {"key": "model", "valueType": "STRING"},
        {"key": "outcome", "valueType": "STRING"}
      ]
    },
    "labelExtractors": {
      "agent": "EXTRACT(jsonPayload.agent_name)",
      "model": "EXTRACT(jsonPayload.model_name)",
      "outcome": "EXTRACT(jsonPayload.outcome)"
    }
  },
  {
    "name": "athena_agent_input_tokens",
    "description": "Input tokens consumed by ADK model calls.",
    "filter": "resource.type=\"cloud_run_revision\" AND jsonPayload.event_name=\"model_call\" AND jsonPayload.input_tokens:*",
    "valueExtractor": "EXTRACT(jsonPayload.input_tokens)",
    "bucketOptions": {"exponentialBuckets": {"numFiniteBuckets": 20, "growthFactor": 2, "scale": 1}},
    "metricDescriptor": {
      "metricKind": "DELTA",
      "valueType": "DISTRIBUTION",
      "unit": "1",
      "labels": [
        {"key": "agent", "valueType": "STRING"},
        {"key": "model", "valueType": "STRING"}
      ]
    },
    "labelExtractors": {
      "agent": "EXTRACT(jsonPayload.agent_name)",
      "model": "EXTRACT(jsonPayload.model_name)"
    }
  },
